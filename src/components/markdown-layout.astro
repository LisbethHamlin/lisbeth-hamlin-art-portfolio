---
import Layout, { type Props as LayoutProps } from './layout.astro';

interface Props {
  frontmatter: {
    layout: string;
    id: string;
    title: string;
    description: string;
  };
}

const { title, description } = Astro.props.frontmatter;
---

<Layout title={title} description={description}>
  <div class="markdown-content">
    <slot />
  </div>
</Layout>
