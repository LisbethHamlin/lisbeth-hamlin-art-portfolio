---
import Header from '@components/header.astro';
import Footer from '@components/footer.astro';
import '@/styles/styles.scss';
import { ClientRouter, fade } from 'astro:transitions';


export interface Props {
  title: string;
}

const siteTitle = `Bryce Mehring` + (Astro.props.title ? ` | ${Astro.props.title}` : '');
const siteDescription = `Bryce Mehring's personal website.`;
const pageFade = fade({ duration: '150ms' });
---

<html lang="en" transition:animate={pageFade}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ClientRouter transition:animate={fade({ duration: '5s' })} />
  </head>
  <body>
    <main class="container lisbeth-hamlin">
      <Header pageTitle={Astro.props.title} />
      <slot />
      <Footer />
    </main>
  </body>
</html>
