---
import Layout from '@/components/layout.astro';
import { artShows } from '@/contentful';
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { urlFromTitle } from '@/utils';

export async function getStaticPaths() {
  return artShows.items.filter((item) => !item.fields.ignore).map((item) => {
    const id = urlFromTitle(item.fields.displayField);
    console.log('id', id);
    return {
      params: { id: urlFromTitle(item.fields.displayField) },
      props: { artShow: item },
    };
  });
}

const { artShow } = Astro.props;
---

<Layout title={artShow.fields.displayField} breadcrumbs={['art-shows', artShow.fields.displayField]}>
  <article set:html={documentToHtmlString(artShow.fields.post)}></article>
</Layout>